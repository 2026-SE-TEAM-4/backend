# 백엔드 환경 변수 예시. 복사해서 .env로 쓰고 비밀값을 채운다.
#   cp .env.example .env
APP_ENV=dev

# PostgreSQL (compose의 postgres 서비스와 일치시킨다)
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
DATABASE_URL=postgresql+asyncpg://app:app@postgres:5432/app

# Redis
REDIS_URL=redis://redis:6379/0

# 인증 (JWT 단일 액세스 토큰)
JWT_SECRET=dev-secret-change-me
JWT_EXPIRE_MIN=60

# 로그인 실패 잠금 (UC23)
LOGIN_FAIL_MAX=5
LOGIN_FAIL_WINDOW_SEC=300
LOGIN_LOCK_MIN=15

# 스케줄러 / 서버풀 메트릭 수집 (수집 구현은 후속 단계)
SCHEDULER_INTERVAL_SEC=60
SERVERPOOL_HOST=host.docker.internal
SERVERPOOL_BASE_PORT=9101

# LLM 원인 요약 잡 (F34/UC25). 키는 환경 변수로만 주입한다(절대 하드코딩 금지).
# 비워 두면 요약 잡은 경고만 남기고 건너뛴다(키 없이도 나머지 기능은 정상 동작).
# Google AI Studio(https://aistudio.google.com/apikey)에서 키를 발급받아 채운다.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
